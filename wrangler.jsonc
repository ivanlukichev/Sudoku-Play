{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sudokus-org",
  "main": "src/index.js",
  "compatibility_date": "2026-03-22",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "force-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": true
  }
}
